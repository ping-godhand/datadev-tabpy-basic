        <objects>
          <object caption='Table Extension' id='_51FB33D69AF74F57B27026779A265493'>
            <properties context=''>
              <analytics-extension-object-node>
                <script-code>import pandas as pd
import yfinance as yf

df = pd.DataFrame(_arg1)

result = pd.DataFrame()

for ticker in [&quot;AAPL&quot;,&quot;GOOG&quot;,&quot;NVDA&quot;]:
    stk = yf.download(ticker, start=&quot;2025-01-01&quot;, end=&quot;2026-03-09&quot;)
    stk = stk[[&quot;Close&quot;]].reset_index()
    stk.columns = stk.columns.droplevel(&quot;Ticker&quot;)
    stk[&quot;Ticker&quot;] = ticker
    stk[&quot;Close&quot;] = stk[&quot;Close&quot;].round(2)
    stk = stk[[&quot;Ticker&quot;,&quot;Date&quot;,&quot;Close&quot;]]
    result = pd.concat([result, stk])

result[&quot;Date&quot;] = result[&quot;Date&quot;].dt.strftime(&quot;%Y-%m-%d&quot;)

return result.to_dict(orient=&quot;list&quot;)</script-code>
