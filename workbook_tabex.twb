          <object caption='Table Extension' id='_5C43B2567A4A435AB3BD369E3142F60E'>
            <properties context=''>
              <analytics-extension-object-node>
                <script-code>import pandas as pd
import yfinance as yf

df = pd.DataFrame(_arg1)

# Download gold price
gold = yf.download(&quot;GC=F&quot;, start=&quot;2025-01-01&quot;, end=&quot;2026-03-09&quot;)
gold = gold[[&quot;Close&quot;]].reset_index()
gold.columns = gold.columns.droplevel(&quot;Ticker&quot;)
gold = gold.rename(columns={&quot;Close&quot;: &quot;XAUUSD&quot;})

# Convert to THB per baht-weight
gold[&quot;THB&quot;] = (gold[&quot;XAUUSD&quot;] / 2.04) * 32
gold[&quot;XAUUSD&quot;] = gold[&quot;XAUUSD&quot;].round(2)
gold[&quot;THB&quot;] = gold[&quot;THB&quot;].round(2)
gold[&quot;Date&quot;] = gold[&quot;Date&quot;].dt.strftime(&quot;%Y-%m-%d&quot;)

return gold[[&quot;Date&quot;,&quot;XAUUSD&quot;,&quot;THB&quot;]].to_dict(orient=&apos;list&apos;)</script-code>
                <input />
                <output>
                  <relation connection='tableau-analytics-extension.1bn3pyo0ncpa2t12sz5nj017xy65' name='Table Extension 3142F60E' table='[public].[Tableau_39_6E47490B-5A31-4AF5-BD01-A3BE0AA55216_1_TableauTempExtSvc]' type='table'>
