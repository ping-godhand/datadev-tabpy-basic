              <bucket>&quot;Improve&quot;</bucket>
            </map>
            <map to='#e15759'>
              <bucket>&quot;Worsen&quot;</bucket>
            </map>
            <map to='#edc948'>
              <bucket>&quot;NoChange&quot;</bucket>
            </map>
            <map to='#f28e2b'>
              <bucket>&quot;New&quot;</bucket>
            </map>
          </encoding>
        </style-rule>
      </style>
      <semantic-values>
        <semantic-value key='[Country].[Name]' value='&quot;United States&quot;' />
      </semantic-values>
      <object-graph>
        <objects>
          <object caption='Table Extension' id='_49B744ED41094C4A8CBE2C886FD11CE8'>
            <properties context=''>
              <analytics-extension-object-node>
                <script-code><![CDATA[import pandas as pd

df = pd.DataFrame(_arg1)

# Fix Thai Buddhist Era year if needed
df['SnapshotDate'] = df['SnapshotDate'].str.replace(
    r'^(\d{4})', lambda m: str(int(m.group(1)) - 543) if int(m.group(1)) > 2500 else m.group(1), regex=True
)
df['SnapshotDate'] = pd.to_datetime(df['SnapshotDate'])

# DPD Bucket
def dpd_bucket(dpd):
    if dpd <= 30:  return "Normal"
    elif dpd <= 60:  return "Mild"
    elif dpd <= 90:  return "Moderate"
    elif dpd <= 120: return "Severe"
    else:            return "Red Zone"

df['DPD_Bucket'] = df['DayPastDue'].apply(dpd_bucket)

# Bucket rank for comparison
bucket_order = {"Normal": 0, "Mild": 1, "Moderate": 2, "Severe": 3, "Red Zone": 4}
df['_rank'] = df['DPD_Bucket'].map(bucket_order)

# Sort and compute status vs previous month
df = df.sort_values(['CustomerID','SnapshotDate']).reset_index(drop=True)
df['_prev'] = df.groupby('CustomerID')['_rank'].shift(1)

def dpd_status(row):
    if pd.isna(row['_prev']):       return "New"
    elif row['_rank'] > row['_prev']: return "Worsen"
    elif row['_rank'] < row['_prev']: return "Improve"
    else:                             return "NoChange"

df['DPD_Status'] = df.apply(dpd_status, axis=1)

# Cleanup
df = df.drop(columns=['_rank','_prev'])
df['SnapshotDate'] = df['SnapshotDate'].astype(str)

return df.to_dict(orient='list')]]></script-code>
                <input>
