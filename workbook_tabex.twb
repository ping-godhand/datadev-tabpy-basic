      <object-graph>
        <objects>
          <object caption='Table Extension' id='_9FBC67FB3AB44C3886B406779F609BF6'>
            <properties context=''>
              <analytics-extension-object-node>
                <script-code>import pandas as pd

df = pd.DataFrame(_arg1)

# Fix Thai Buddhist Era year
df[&apos;OrderDate&apos;] = df[&apos;OrderDate&apos;].str.replace(
    r&apos;^(\d{4})&apos;, lambda m: str(int(m.group(1)) - 543), regex=True
)
df[&apos;OrderDate&apos;] = pd.to_datetime(df[&apos;OrderDate&apos;])

# Tenure &amp; Recency per customer
cust = df.groupby(&apos;CustomerName&apos;)[&apos;OrderDate&apos;].agg([&apos;min&apos;,&apos;max&apos;])
cust[&apos;Tenure&apos;] = (cust[&apos;max&apos;] - cust[&apos;min&apos;]).dt.days
cust[&apos;Recency&apos;] = (df[&apos;OrderDate&apos;].max() - cust[&apos;max&apos;]).dt.days

# Normalize &amp; compute churn
mn = lambda s: (s - s.min()) / (s.max() - s.min()) if s.max() != s.min() else s * 0.0
cust[&apos;Churn&apos;] = (1 - mn(cust[&apos;Tenure&apos;])) * mn(cust[&apos;Recency&apos;])

# Join back
df[&apos;OrderDate&apos;] = df[&apos;OrderDate&apos;].astype(str)
df = df.merge(cust[[&apos;Tenure&apos;,&apos;Recency&apos;,&apos;Churn&apos;]], on=&apos;CustomerName&apos;, how=&apos;left&apos;)

return df.to_dict(orient=&apos;list&apos;)</script-code>
