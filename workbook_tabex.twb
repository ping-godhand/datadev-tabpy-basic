      <object-graph>
        <objects>
          <object caption='Table Extension' id='_366D1AB8E3B94C79BA6BF4116A3C8F1B'>
            <properties context=''>
              <analytics-extension-object-node>
                <script-code>import pandas as pd
import os
import json
from openai import OpenAI

client = OpenAI(api_key=os.environ[&apos;OPENAI_API_KEY&apos;])

RESPONSE_FORMAT = {
    &quot;type&quot;: &quot;json_schema&quot;,
    &quot;json_schema&quot;: {
        &quot;name&quot;: &quot;call_analysis&quot;,
        &quot;strict&quot;: True,
        &quot;schema&quot;: {
            &quot;type&quot;: &quot;object&quot;,
            &quot;properties&quot;: {
                &quot;CustomerName&quot;:   {&quot;type&quot;: &quot;string&quot;},
                &quot;CustomerIntent&quot;: {&quot;type&quot;: &quot;string&quot;},
                &quot;Resolution&quot;:     {&quot;type&quot;: &quot;string&quot;},
            },
            &quot;required&quot;: [&quot;CustomerName&quot;, &quot;CustomerIntent&quot;, &quot;Resolution&quot;],
            &quot;additionalProperties&quot;: False,
        },
    },
}

df = pd.DataFrame(_arg1)

names, intents, resolutions = [], [], []

for s in df[&apos;TextScript&apos;]:
    resp = client.chat.completions.create(
        model=&apos;gpt-4.1-mini&apos;,
        messages=[
            {&apos;role&apos;: &apos;system&apos;, &apos;content&apos;: &apos;Extract CustomerName, CustomerIntent, Resolution from this call transcript. Each value under 30 characters.&apos;},
            {&apos;role&apos;: &apos;user&apos;, &apos;content&apos;: s}
        ],
        temperature=0,
        response_format=RESPONSE_FORMAT
    )
    r = json.loads(resp.choices[0].message.content)
    names.append(r[&apos;CustomerName&apos;])
    intents.append(r[&apos;CustomerIntent&apos;])
    resolutions.append(r[&apos;Resolution&apos;])

df[&apos;CustomerName&apos;] = names
df[&apos;CustomerIntent&apos;] = intents
df[&apos;Resolution&apos;] = resolutions

return df.to_dict(orient=&apos;list&apos;)</script-code>
