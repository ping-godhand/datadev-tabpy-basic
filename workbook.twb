            <column caption='TABPY_Cluster' datatype='integer' name='[Calculation_1061442188207136770]' role='measure' type='ordinal'>
              <calculation class='tableau' formula='SCRIPT_INT(&quot;&#10;import pandas as pd&#10;from sklearn.preprocessing import StandardScaler&#10;from sklearn.cluster import KMeans, DBSCAN, AgglomerativeClustering, MiniBatchKMeans, AffinityPropagation&#10;&#10;method = _arg1[0]&#10;number = int(_arg2[0])&#10;col_1 = _arg3&#10;col_2 = _arg4&#10;&#10;c = list(zip(col_1, col_2))&#10;df = pd.DataFrame(c, columns=[&apos;col_1&apos;,&apos;col_2&apos;])&#10;df = df.fillna(df.mean())&#10;&#10;n = len(df)&#10;if n &lt; 2:&#10;    return [0] * n&#10;&#10;sc = StandardScaler()&#10;x = sc.fit_transform(df)&#10;&#10;k = min(number, n)&#10;&#10;if method == &apos;kmeans&apos;:&#10;    result = KMeans(n_clusters=k).fit_predict(x).tolist()&#10;elif method == &apos;dbscan&apos;:&#10;    result = DBSCAN().fit_predict(x).tolist()&#10;elif method == &apos;agglo&apos;:&#10;    result = AgglomerativeClustering(n_clusters=k).fit_predict(x).tolist()&#10;elif method == &apos;mini&apos;:&#10;    result = MiniBatchKMeans(n_clusters=k).fit_predict(x).tolist()&#10;elif method == &apos;affinity&apos;:&#10;    result = AffinityPropagation().fit_predict(x).tolist()&#10;else:&#10;    result = [0] * n&#10;&#10;return result&#10;&quot;, ATTR([Parameters].[Parameter 1]), ATTR([Parameters].[Parameter 2]), SUM([Sales]), SUM([Profit]))'>
