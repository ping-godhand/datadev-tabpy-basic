        <calculation class='tableau' formula='SCRIPT_STR(&quot;&#10;&#10;import os&#10;from openai import OpenAI&#10;&#10;client = OpenAI(api_key=os.environ[&apos;OPENAI_API_KEY&apos;])&#10;scripts = _arg1&#10;results = []&#10;&#10;for s in scripts:&#10;    resp = client.chat.completions.create(&#10;        model=&apos;gpt-4.1-mini&apos;,&#10;        messages=[&#10;            {&apos;role&apos;: &apos;system&apos;, &apos;content&apos;: &apos;Extract customer intent from this call transcript. Reply with ONLY the intent in under 30 characters. No JSON, no explanation.&apos;},&#10;            {&apos;role&apos;: &apos;user&apos;, &apos;content&apos;: s}&#10;        ],&#10;        temperature=0&#10;    )&#10;    results.append(resp.choices[0].message.content.strip())&#10;&#10;return results&#10;&#10;&quot;, ATTR([TextScript]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
