      <column caption='TABPY_Predict' datatype='real' name='[Calculation_3615859880431619]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SCRIPT_REAL(&quot;&#10;import pandas as pd&#10;import numpy as np&#10;from sklearn.linear_model import LinearRegression&#10;from sklearn.preprocessing import PolynomialFeatures&#10;&#10;method = _arg1[0]&#10;items = _arg2&#10;prices = _arg3&#10;&#10;df = pd.DataFrame({&apos;item&apos;: items, &apos;price&apos;: prices})&#10;&#10;train = df.dropna(subset=[&apos;price&apos;])&#10;X_train = train[[&apos;item&apos;]]&#10;y_train = train[&apos;price&apos;]&#10;&#10;X_all = df[[&apos;item&apos;]]&#10;&#10;if method == &apos;Linear&apos;:&#10;    model = LinearRegression()&#10;    model.fit(X_train, y_train)&#10;    result = model.predict(X_all).tolist()&#10;&#10;elif method == &apos;Quadratic&apos;:&#10;    poly = PolynomialFeatures(degree=2, include_bias=False)&#10;    X_poly_train = poly.fit_transform(X_train)&#10;    model = LinearRegression()&#10;    model.fit(X_poly_train, y_train)&#10;    X_poly_all = poly.transform(X_all)&#10;    result = model.predict(X_poly_all).tolist()&#10;&#10;else:&#10;    result = [0.0] * len(df)&#10;&#10;return result&#10;&quot;, ATTR([Parameters].[Parameter 3]), SUM([Item]), SUM([Price]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
